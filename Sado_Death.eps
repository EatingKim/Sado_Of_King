            break;
        case 10: //E-E
            if (timer < 45) 
            {
                if (timer%2 == 0)
                {
                    const x, y = getlocTL(targetLoc);
                    const temp = (timer/2)%4;
                    TE.SetPColor(Ncp, array_ColorLine_Dark[(timer/5)%8]);
                    for (var i = 1; i < 5; i++) {
                        setloc(tempLoc, x + dd.shape_Straight_dy[temp]*i, y + dd.shape_Straight_dy[temp]*i);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4);
                        TE.SetUnitColorEPD(epd, Ncp);
                    }
                    KillUnit(effect_Unit, cp);
                }
                if (timer%2 == 1)
                {
                    const x, y = getlocTL(targetLoc);
                    const temp = (timer-1)/2%4;
                    for (var i = 1; i < 5; i++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[temp]*i, y + dd.shape_Cross_dy[temp]*i);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4);
                        TE.SetUnitColorEPD(epd, Ncp);
                    }
                    KillUnit(effect_Unit, cp);
                }
            }
            break;
        case 11: //R
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(targetLoc, x, y);
            }
            if (timer < 160)
            {
                const x, y = getlocTL(targetLoc);

                // --- [0] 16개 점 그룹 (Size 4) ---
                acc_Square[0] += 16;
                if (acc_Square[0] >= 80) {
                    acc_Square[0] -= 80;
                    pos_Square[0] = (pos_Square[0] + 1) % 16; // 한 칸 전진
                    
                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[0] + i * 4) % 16; // 4칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_5[index];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, tempLoc);
                    }
                    KillUnit(skill_Unit_2, cp);
                }

                // --- [1] 24개 점 그룹 (Size 6) ---
                acc_Square[1] += 24;
                if (acc_Square[1] >= 80) {
                    acc_Square[1] -= 80;
                    pos_Square[1] = (pos_Square[1] + 1) % 24; // 한 칸 전진

                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[1] + i * 6) % 24; // 6칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_7[index];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, tempLoc);
                    }
                    KillUnit(skill_Unit_2, cp);
                }

                // --- [2] 32개 점 그룹 (Size 8) ---
                acc_Square[2] += 32;
                if (acc_Square[2] >= 80) {
                    acc_Square[2] -= 80;
                    pos_Square[2] = (pos_Square[2] + 1) % 32; // 한 칸 전진

                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[2] + i * 8) % 32; // 8칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_9[index];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, tempLoc);
                    }
                    KillUnit(skill_Unit_2, cp);
                }

                // --- [3] 40개 점 그룹 (Size 10) ---
                acc_Square[3] += 40;
                if (acc_Square[3] >= 80) {
                    acc_Square[3] -= 80;
                    pos_Square[3] = (pos_Square[3] + 1) % 40; // 한 칸 전진

                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[3] + i * 10) % 40; // 8칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_11[index];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, tempLoc);
                    }
                    KillUnit(skill_Unit_2, cp);
                }
                if (timer%16 == 0)
                {
                    const x, y = getlocTL(targetLoc);
                    for (var i = 0; i < 8; i++) {
                        const dx, dy = dd.shape_Square_3[i];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    }
                    KillUnit(effect_Unit, cp);
                }
            }
            break;
    
        default:
            break;
    }
    if (timer == max) 
    {
        Death_UnitSetting_Reset();
        return true;
    }
    return false;
}
function Death_Skill_Main(cp, sado_Main: EUDArray) {
    const sado = sdo.Sado.cast(sado_Main[cp]);
    for (var i = 1; i < 30; i++) {
        const info = sdo.Skill_Info.cast(sado.info[i]);
        var cond = 0;
        if (info.isActived)
        {
            if (info.isEnhance) cond = Death_Skill_Enhance(cp, sado.epd, info.type, info.timer, info.maxtime);
            else cond = Death_Skill(cp, sado.epd, info.type, info.timer, info.maxtime);
            info.timer += 1;
        }
        if (cond) sado.ComboSetting(i);
    }
}
function Death_UnitGroup(cp, minion_order) {
    foreach (unit : Death_SkillGroup.cploop) {
        foreach (dead : unit.dying) {
            
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        if (type == 1) 
        {
            //W-W 공격후 모이기
            if (timer == 0)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 12;
                unit.move_cp(0x28/4);
                const x, y = cunit.posX, cunit.posY;
                setloc(tempLoc, x, y);
                Order(8, cp, tempLoc, Move, heroLoc);
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 2)
        {
            //W-W모인 이후 사망
            if (timer == 0)
            {
                cunit.orderID = 0;
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
    }
    //minion_order : 1: 집결, 2: 거점, 4: 생성(800min)
    if (minion_order & 4)
    {
        if (Command(cp, AtLeast, minion_Limit, death_Minion_Unit))
        {
            printAllAt(6, "\x04하수인 소환 실패 \x02(\x04최대치 제한!\x02)");
            return;
        }
        if (Accumulate(cp, AtLeast, minion_Cost, Ore)) //미네랄확인
        {
            //텍스트 출력
            const x, y = getlocTL(heroLoc);
            effect_Unit_Sprite.image = sc.image_Queen;
            //하수인 생성
            const epd = sy.Unit_Create(cp, death_Minion_Unit, bufferLoc, heroLoc);
            //이펙트 유닛 생성
            sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
            KillUnit(effect_Unit, cp);
            sc.Reset_Change(effect_Unit_Sprite);
            if (epd > 0)
            {
                //자원 감소
                SetResources(cp, Subtract, minion_Cost, Ore);
                printAllAt(6, "\x04하수인 소환 성공 \x02(\x08-\x07{}\x03Gold\x02)", minion_Cost);
                Death_MinionGroup_Main.add(epd);
                sy.SetExtraDb(epd, 0, 5);
            } else {
                //유닛제한으로 생성 실패
                printAllAt(6, "\x04하수인 소환 실패 \x02(\x04유닛 제한 오류!\x02)");
            }
        } else {
            //자원부족으로 하수인 생성 실패
            printAllAt(6, "\x04하수인 소환 실패 \x02(\x04자원 부족!\x02)");
        }
    }
    //거점 생성
    if (minion_order & 2)
    {
        for (var i = 0; i < 3; i++) {
            if (FOB_Exist[i] == false)
            {
                //최초 생성
                const epd = sy.Unit_Create(cp, FOB_Unit, bufferLoc, heroLoc);
                wwrite_epd(epd + 0x8C/4, 0, i);
                FOB_Epd[i] = epd;
                FOB_Exist[i] = true;
                break;
            }
        }
    }
    foreach (unit : Death_MinionGroup_Main.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        if (minion_order & 1)
        {
            //집결 명령
            cunit.unknown0x86 = 1;
            cunit.unknown0x8C = 0;
            const x, y = getlocTL(mouseLoc+cp);
            sy.SetExtraDb(cunit, 1, x);
            sy.SetExtraDb(cunit, 2, y);
            continue;
        }
        if (type == 0)
        {
            //휴식 상태
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                //거점 유닛 할당시키기
                for (var i = 0; i < 3; i++) {
                    if (FOB_Exist[i] == true && FOB_Count[i] < 6)
                    {
                        FOB_Count[i] += 1;
                        const epd = unit.epd;
                        if (i == 0) Death_MinionGroup_FOB_1.add(epd);
                        else if (i == 1) Death_MinionGroup_FOB_2.add(epd);
                        else if (i == 2) Death_MinionGroup_FOB_3.add(epd);
                        unit.remove();
                    }
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1) 
        {
            //마우스 위치에 집결
            const tx = sy.GetExtraDb(cunit, 1);
            const ty = sy.GetExtraDb(cunit, 2);
            setloc(tempLoc, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(death_Minion_Unit, cp, minionLoc, Move, tempLoc);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, tempLoc) < 128)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 6;
                Order(death_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                cunit.set_collision();
            }
        }
        else if (type == 2)
        {
            //약간의 버퍼링
            if (timer == 0)
            {
                cunit.unknown0x86 = 0;
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 3)
        {
            //거점 할당 해제시 영웅에게 모이기
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                const tx, ty = getlocTL(heroLoc);
                cunit.setloc(minionLoc);
                Order(death_Minion_Unit, cp, minionLoc, Move, heroLoc);
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, heroLoc) < 128)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 6;
                Order(death_Minion_Unit, cp, minionLoc, Attack, heroLoc);
                cunit.set_collision();
            }
        }
    }
    foreach (unit : Death_MinionGroup_FOB_1.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[0] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Death_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[0] + 0x28/4);
                setloc(tempLoc, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, tempLoc) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(death_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(death_Minion_Unit, cp, minionLoc, Patrol, tempLoc);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[0] + 0x28/4);
            setloc(tempLoc, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(death_Minion_Unit, cp, minionLoc, Move, tempLoc);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, tempLoc) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(death_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                cunit.set_collision();
            }
        }
    }
    foreach (unit : Death_MinionGroup_FOB_2.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[1] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Death_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[1] + 0x28/4);
                setloc(tempLoc, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, tempLoc) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(death_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(death_Minion_Unit, cp, minionLoc, Patrol, tempLoc);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[1] + 0x28/4);
            setloc(tempLoc, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(death_Minion_Unit, cp, minionLoc, Move, tempLoc);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, tempLoc) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(death_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                cunit.set_collision();
            }
        }
    }
    foreach (unit : Death_MinionGroup_FOB_3.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[2] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Death_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[2] + 0x28/4);
                setloc(tempLoc, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, tempLoc) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(death_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(death_Minion_Unit, cp, minionLoc, Patrol, tempLoc);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[2] + 0x28/4);
            setloc(tempLoc, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(death_Minion_Unit, cp, minionLoc, Move, tempLoc);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, tempLoc) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(death_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                cunit.set_collision();
            }
        }
    }
}

function Death_FOB_Remove(cp, index) {
    //내부 값 초기화
    FOB_Count[index] = 0;
    FOB_Epd[index] = 0;
    FOB_Exist[index] = false;
}