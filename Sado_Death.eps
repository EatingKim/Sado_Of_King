            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_PeachD);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_32[i];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            break;
        case 6: //W-Q
            if (timer%48 == 0 && timer < 20*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            if (timer%24 == 0 && timer > 20*24 && timer < 25*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
