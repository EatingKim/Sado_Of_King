                        setloc(tempLoc, x + dd.shape_Straight_dy[i]*j, y + dd.shape_Straight_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                        Unit_Color_Change(cp, epd, color_ArmyD);
