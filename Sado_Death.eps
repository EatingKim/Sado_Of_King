function Death_Skill(cp, epd, type, timer, max) {
    if (timer == 0) Death_UnitSetting(cp, type, 0);
    const Ncp = cp + 8;
    switch (type) {
        case 1: //Q
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(searchLoc, x, y);
                dilateloc(searchLoc, 128, 128);
                RemoveUnit(0, P12);
                MoveLocation(targetLoc, "Men", NonAlliedVictoryPlayers, searchLoc);
                TE.AttackGround(searchLoc, targetLoc, skill_Unit_2, dummyUnit, cp);
            }
            else if (timer == 4) {
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    }
                }
            }
            else if (timer == 6)
            {
                RemoveUnit(effect_Unit, cp);
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                        Unit_Color_Change(cp, epd, color_Black);
                    }
                }
            }
            break;
        case 2: //Q-Q
            if (timer == 0 || timer == 8)
            {
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 3; j++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    }
                }
            }
            else if (timer == 2 || timer == 10)
            {
                RemoveUnit(effect_Unit, cp);
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 3; j++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                        Unit_Color_Change(cp, epd, color_ArmyD);
                    }
                }
            }
            else if (timer == 4)
            {
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 3; j++) {
                        setloc(tempLoc, x + dd.shape_Straight_dy[i]*j, y + dd.shape_Straight_dy[i]*j);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    }
                }
            }
            else if (timer == 6)
            {
                RemoveUnit(effect_Unit, cp);
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 3; j++) {
                        setloc(tempLoc, x + dd.shape_Straight_dy[i]*j, y + dd.shape_Straight_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                        Unit_Color_Change(cp, epd, color_ArmyD);
                    }
                }
            }
            break;
        case 3: //Q-W
            if (timer == 2)
            {
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_64[i*2];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                }
            }
            else if (timer == 4)
            {
                KillUnit(effect_Unit, cp);
                TE.AttackGround(targetLoc, targetLoc, skill_Unit_2, dummyUnit, cp);
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 3; j++) {
                        setloc(tempLoc, x + dd.shape_Straight_dy[i]*j, y + dd.shape_Straight_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                        Unit_Color_Change(cp, epd, color_ArmyD);
                    }
                }
            }
            break;
        case 4: //Q-E
            if (timer == 0 || timer == 10)
            {
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_32[i*2];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                }
            }
            if (timer == 2 || timer == 12)
            {
                RemoveUnit(effect_Unit, cp);
            }
            if (timer == 3 || timer == 13)
            {
                const x, y = getlocTL(targetLoc);
                const offset = (timer == 3) ? 0 : 1;
                TE.SetPColor(Ncp, color_ArmyF);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_32[i*2 + offset];
                    setloc(tempLoc, x + dx, y + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_64[i*2];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                }
            }
            if (timer == 5 || timer == 15)
            {
                RemoveUnit(effect_Unit, cp);
            }
            if (timer == 6 || timer == 16)
            {
                const x, y = getlocTL(targetLoc);
                const offset = (timer == 6) ? 1 : 0;
                TE.SetPColor(Ncp, color_ArmyD);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_64[i*2+offset];
                    setloc(tempLoc, x + dx, y + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_96[i*2];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                }
            }
            if (timer == 81 || timer == 18)
            {
                RemoveUnit(effect_Unit, cp);
            }
            if (timer == 9 || timer == 19)
            {
                const x, y = getlocTL(targetLoc);
                const offset = (timer == 9) ? 0 : 1;
                TE.SetPColor(Ncp, color_Black);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_96[i*2+offset];
                    setloc(tempLoc, x + dx, y + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
            }
            break;
        case 5: //W
            if (timer == 3)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_White);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_128[i*2];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            if (timer == 6)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_Wine);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_96[i*2];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            if (timer == 9)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_Yellow);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_64[i*2];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            if (timer == 12)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_PeachD);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_32[i*2];
                    setloc(tempLoc, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            break;
        case 6: //W-Q
            if (timer%48 == 0 && timer < 15*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            if (timer%24 == 0 && timer > 15*24 && timer < 18*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            if (timer%8 == 0 && timer > 18*24 && timer < 20*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            const amount = 50*256/24;
            sy.Unit_Healing_Count(epd, cp, amount);
            break;
        case 7: //W-W
            if (timer%2 == 0 && timer < 64)
            {
                const x, y = getlocTL(heroLoc);
                const tick = (timer/2)%16;
                const dx, dy = dd.shape_Circle_32[tick];
                setloc(tempLoc, x + dx, y + dy);
                const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, sy.NONE);
                Death_SkillGroup.add(epd);
                bwrite_epd(epd + 0x84/4, 2, 1); //행동타입
                bwrite_epd(epd + 0x8C/4, 0, 4); //행동 타이머
                sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                KillUnit(effect_Unit, cp);
                TE.SetUnitColorEPD(epd, Ncp);
            }
            if (timer%2 == 0 && timer < 64)
            {
                const x, y = getlocTL(heroLoc);
                const tick = (timer/2)%16;
                const dx, dy = dd.shape_Circle_64[tick];
                setloc(tempLoc, x + dx, y + dy);
                const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, sy.NONE);
                Death_SkillGroup.add(epd);
                bwrite_epd(epd + 0x84/4, 2, 1); //행동타입
                bwrite_epd(epd + 0x8C/4, 0, 4); //행동 타이머
                sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                KillUnit(effect_Unit, cp);
                TE.SetUnitColorEPD(epd, Ncp);
            }
            if (timer%2 == 0 && timer < 64)
            {
                const x, y = getlocTL(heroLoc);
                const tick = (timer/2)%16;
                const dx, dy = dd.shape_Circle_96[tick];
                setloc(tempLoc, x + dx, y + dy);
                const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, sy.NONE);
                Death_SkillGroup.add(epd);
                bwrite_epd(epd + 0x84/4, 2, 1); //행동타입
                bwrite_epd(epd + 0x8C/4, 0, 4); //행동 타이머
                sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                KillUnit(effect_Unit, cp);
                TE.SetUnitColorEPD(epd, Ncp);
            }
            if (timer%2 == 0) 
            {
                TE.SetPColor(Ncp, array_ColorLine_Dark[timer/2%8]);
            }
            break;
        case 8: //W-E
            break;
        case 9: //E
            if (timer%5 == 0 && timer < 12)
            {
                const x, y = posread_epd(epd + 0x28/4);
                setloc(searchLoc, x, y);
                dilateloc(searchLoc, 160, 160);
                RemoveUnit(0, P12);
                MoveLocation(targetLoc, "Men", NonAlliedVictoryPlayers, searchLoc);
                const tx, ty = getlocTL(targetLoc);
                sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc, 4);
                TE.SetPColor(Ncp, array_ColorLine_Dark[timer/5]);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Square_3[i];
                    setloc(tempLoc, tx + dx, ty + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Square_5[i];
                    setloc(tempLoc, tx + dx, ty + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
            }
            break;
        case 10: //E-E
            if (timer < 30) 
            {
                if (timer%2 == 0)
                {
                    const x, y = getlocTL(targetLoc);
                    const temp = (timer/2)%4;
                    TE.SetPColor(Ncp, array_ColorLine_Dark[(timer/5)%8]);
                    for (var i = 1; i < 4; i++) {
                        setloc(tempLoc, x + dd.shape_Straight_dy[temp]*i, y + dd.shape_Straight_dy[temp]*i);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4);
                        TE.SetUnitColorEPD(epd, Ncp);
                    }
                    KillUnit(effect_Unit, cp);
                }
                if (timer%2 == 1)
                {
                    const x, y = getlocTL(targetLoc);
                    const temp = (timer-1)/2%4;
                    for (var i = 1; i < 4; i++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[temp]*i, y + dd.shape_Cross_dy[temp]*i);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4);
                        TE.SetUnitColorEPD(epd, Ncp);
                    }
                    KillUnit(effect_Unit, cp);
                }
            }
            break;
        case 11: //R
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(targetLoc, x, y);
                for (var i = 0; i < 4; i++) {
                    acc_Square[i] = 0;
                }
            }
            if (timer < 120)
            {
                const x, y = getlocTL(targetLoc);
                // --- [0] 16개 점 그룹 (Size 4) ---
                acc_Square[0] += 16;
                if (acc_Square[0] >= 80) {
                    acc_Square[0] -= 80;
                    pos_Square[0] = (pos_Square[0] + 1) % 16; // 한 칸 전진
                    
                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[0] + i * 4) % 16; // 4칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_5[index];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, tempLoc);
                    }
                    KillUnit(skill_Unit_2, cp);
                }

                // --- [1] 24개 점 그룹 (Size 6) ---
                acc_Square[1] += 24;
                if (acc_Square[1] >= 80) {
                    acc_Square[1] -= 80;
                    pos_Square[1] = (pos_Square[1] + 1) % 24; // 한 칸 전진

                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[1] + i * 6) % 24; // 6칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_7[index];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, tempLoc);
                    }
                    KillUnit(skill_Unit_2, cp);
                }

                // --- [2] 32개 점 그룹 (Size 8) ---
                acc_Square[2] += 32;
                if (acc_Square[2] >= 80) {
                    acc_Square[2] -= 80;
                    pos_Square[2] = (pos_Square[2] + 1) % 32; // 한 칸 전진

                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[2] + i * 8) % 32; // 8칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_9[index];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, tempLoc);
                    }
                    KillUnit(skill_Unit_2, cp);
                }
                if (timer%16 == 0)
                {
                    const x, y = getlocTL(targetLoc);
                    for (var i = 0; i < 8; i++) {
                        const dx, dy = dd.shape_Square_3[i];
                        setloc(tempLoc, x + dx, y + dy);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    }
                    KillUnit(effect_Unit, cp);
                }
            }
            break;
    
        default:
            break;
    }
    if (timer == max) 
    {
        Death_UnitSetting_Reset();
        return true;
    }
    return false;
}
function Death_Skill_Enhance(cp, epd, type, timer, max) {
    if (timer == 0) Death_UnitSetting(cp, type, 1);
    const Ncp = cp + 8;
    switch (type) {
        case 1: //Q
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(searchLoc, x, y);
                dilateloc(searchLoc, 196, 196);
                RemoveUnit(0, P12);
                MoveLocation(targetLoc, "Men", NonAlliedVictoryPlayers, searchLoc);
                TE.AttackGround(searchLoc, targetLoc, skill_Unit_2, dummyUnit, cp);
            }
            else if (timer == 4) {
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    }
                }
            }
            else if (timer == 6)
            {
                RemoveUnit(effect_Unit, cp);
                const x, y = getlocTL(targetLoc);
                TE.SetPColor(Ncp, color_Black);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                        TE.SetUnitColorEPD(epd, Ncp);
                    }
                    setloc(tempLoc, x + dd.shape_Straight_dy[i], y + dd.shape_Straight_dy[i]);
                    const epd_2 = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 3);
                    TE.SetUnitColorEPD(epd_2, Ncp);
                }
            }
            break;
        case 2: //Q-Q
            if (timer == 0 || timer == 8)
            {
                const x, y = getlocTL(targetLoc);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(tempLoc, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    }
                }
            }
            else if (timer == 2 || timer == 10)
            {
