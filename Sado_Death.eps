                }
                KillUnit(effect_Unit, cp);
            }
            if (timer == 6)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_Wine);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_96[i];
