            }
            if (timer == 9 || timer == 19 || timer == 29)
            {
                const x, y = getlocTL(targetLoc_F);
                const offset = (timer == 9 || timer == 29) ? 0 : 1;
                TE.SetPColor(Ncp, color_Black);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_96[i*2+offset];
                    setloc(targetLoc_S, x + dx, y + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
            }
            break;
        case 5: //W
            if (timer == 3)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_White);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_128[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            if (timer == 6)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_Wine);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_96[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            if (timer == 9)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_Yellow);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_64[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            if (timer == 12)
            {
                const x, y = getlocTL(heroLoc);
                TE.SetPColor(Ncp, color_PeachD);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_32[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                KillUnit(effect_Unit, cp);
            }
            break;
        case 6: //W-Q
            if (timer%48 == 0 && timer < 20*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            if (timer%24 == 0 && timer > 20*24 && timer < 25*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            if (timer%8 == 0 && timer > 25*24 && timer < 30*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            const amount = 50*256/24;
            sy.Unit_Healing_Count(CUnit(epd), cp, amount);
            //하수인 회복 부분은 나중에
            break;
        case 7: //W-W
            if (timer%2 == 0 && timer < 96)
            {
                const x, y = getlocTL(heroLoc);
                const tick = (timer/2)%16;
                const dx, dy = dd.shape_Circle_32[tick];
                setloc(targetLoc_S, x + dx, y + dy);
                const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, sy.NONE);
                Extip_SkillGroup.add(epd);
                bwrite_epd(epd + 0x84/4, 2, 1); //행동타입
                bwrite_epd(epd + 0x8C/4, 0, 4); //행동 타이머
                sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                KillUnit(effect_Unit, cp);
                TE.SetUnitColorEPD(epd, Ncp);
            }
            if (timer%2 == 0 && timer < 96)
            {
                const x, y = getlocTL(heroLoc);
                const tick = (timer/2)%16;
                const dx, dy = dd.shape_Circle_64[tick];
                setloc(targetLoc_S, x + dx, y + dy);
                const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, sy.NONE);
                Extip_SkillGroup.add(epd);
                bwrite_epd(epd + 0x84/4, 2, 1); //행동타입
                bwrite_epd(epd + 0x8C/4, 0, 4); //행동 타이머
                sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                KillUnit(effect_Unit, cp);
                TE.SetUnitColorEPD(epd, Ncp);
            }
            if (timer%2 == 0 && timer < 96)
            {
                const x, y = getlocTL(heroLoc);
                const tick = (timer/2)%16;
                const dx, dy = dd.shape_Circle_96[tick];
                setloc(targetLoc_S, x + dx, y + dy);
                const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, sy.NONE);
                Extip_SkillGroup.add(epd);
                bwrite_epd(epd + 0x84/4, 2, 1); //행동타입
                bwrite_epd(epd + 0x8C/4, 0, 4); //행동 타이머
                sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                KillUnit(effect_Unit, cp);
                TE.SetUnitColorEPD(epd, Ncp);
            }
            if (timer%2 == 0) 
            {
                TE.SetPColor(Ncp, array_ColorLine_Dark[timer/2%8]);
            }
            break;
        case 8: //W-E
            break;
        case 9: //E
            if (timer%5 == 0 && timer < 12)
            {
                const x, y = posread_epd(epd + 0x28/4);
                setloc(searchLoc, x, y);
                dilateloc(searchLoc, 160, 160);
                RemoveUnit(0, P12);
                MoveLocation(targetLoc_F, "Men", NonAlliedVictoryPlayers, searchLoc);
                const tx, ty = getlocTL(targetLoc_F);
                sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_F, 4);
                TE.SetPColor(Ncp, array_ColorLine_Dark[timer/5]);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Square_3[i];
                    setloc(targetLoc_S, tx + dx, ty + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Square_5[i];
                    setloc(targetLoc_S, tx + dx, ty + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                for (var i = 0; i < 24; i++) {
                    const dx, dy = dd.shape_Square_7[i];
                    setloc(targetLoc_S, tx + dx, ty + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
            }
            break;
        case 10: //E-E
            if (timer < 45) 
            {
                if (timer%2 == 0)
                {
                    const x, y = getlocTL(targetLoc_F);
                    const temp = (timer/2)%4;
                    TE.SetPColor(Ncp, array_ColorLine_Dark[(timer/5)%8]);
                    for (var i = 1; i < 5; i++) {
                        setloc(targetLoc_S, x + dd.shape_Straight_dy[temp]*i, y + dd.shape_Straight_dy[temp]*i);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4);
                        TE.SetUnitColorEPD(epd, Ncp);
                    }
                    KillUnit(effect_Unit, cp);
                }
                if (timer%2 == 1)
                {
                    const x, y = getlocTL(targetLoc_F);
                    const temp = (timer-1)/2%4;
                    for (var i = 1; i < 5; i++) {
                        setloc(targetLoc_S, x + dd.shape_Cross_dx[temp]*i, y + dd.shape_Cross_dy[temp]*i);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4);
                        TE.SetUnitColorEPD(epd, Ncp);
                    }
                    KillUnit(effect_Unit, cp);
                }
            }
            break;
        case 11: //R
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(targetLoc_F, x, y);
            }
            if (timer < 160)
            {
                const x, y = getlocTL(targetLoc_F);

                // --- [0] 16개 점 그룹 (Size 4) ---
                acc_Square[0] += 16;
                if (acc_Square[0] >= 80) {
                    acc_Square[0] -= 80;
                    pos_Square[0] = (pos_Square[0] + 1) % 16; // 한 칸 전진
                    
                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[0] + i * 4) % 16; // 4칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_5[index];
                        setloc(targetLoc_S, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, targetLoc_S);
                    }
                    KillUnit(skill_Unit_2, cp);
                }

                // --- [1] 24개 점 그룹 (Size 6) ---
                acc_Square[1] += 24;
                if (acc_Square[1] >= 80) {
                    acc_Square[1] -= 80;
                    pos_Square[1] = (pos_Square[1] + 1) % 24; // 한 칸 전진

                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[1] + i * 6) % 24; // 6칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_7[index];
                        setloc(targetLoc_S, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, targetLoc_S);
                    }
                    KillUnit(skill_Unit_2, cp);
                }

                // --- [2] 32개 점 그룹 (Size 8) ---
                acc_Square[2] += 32;
                if (acc_Square[2] >= 80) {
                    acc_Square[2] -= 80;
                    pos_Square[2] = (pos_Square[2] + 1) % 32; // 한 칸 전진

                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[2] + i * 8) % 32; // 8칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_9[index];
                        setloc(targetLoc_S, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, targetLoc_S);
                    }
                    KillUnit(skill_Unit_2, cp);
                }

                // --- [3] 40개 점 그룹 (Size 10) ---
                acc_Square[3] += 40;
                if (acc_Square[3] >= 80) {
                    acc_Square[3] -= 80;
                    pos_Square[3] = (pos_Square[3] + 1) % 40; // 한 칸 전진

                    for (var i = 0; i < 4; i++) {
                        const index = (pos_Square[3] + i * 10) % 40; // 8칸 간격으로 4개 생성
                        const dx, dy = dd.shape_Square_11[index];
                        setloc(targetLoc_S, x + dx, y + dy);
                        sy.Unit_RemoveEffect(sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4));
                        sy.Unit_Create(cp, skill_Unit_2, bufferLoc, targetLoc_S);
                    }
                    KillUnit(skill_Unit_2, cp);
                }
                if (timer%16 == 0)
                {
                    const x, y = getlocTL(targetLoc_F);
                    for (var i = 0; i < 8; i++) {
                        const dx, dy = dd.shape_Square_3[i];
                        setloc(targetLoc_S, x + dx, y + dy);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    }
                    KillUnit(effect_Unit, cp);
                }
            }
            break;
    
        default:
            break;
    }
    if (timer == max) 
    {
        Extip_UnitSetting_Reset();
        return true;
    }
    return false;
}
function Extip_Skill_Main(cp, sado_Main: EUDArray) {
    const sado = sdo.Sado.cast(sado_Main[cp]);
    for (var i = 1; i < 30; i++) {
        const info = sdo.Skill_Info.cast(sado.info[i]);
        var cond = 0;
        if (info.isActived)
        {
            if (info.isEnhance) cond = Extip_Skill_Enhance(cp, sado.epd, info.type, info.timer, info.maxtime);
            else cond = Extip_Skill(cp, sado.epd, info.type, info.timer, info.maxtime);
            info.timer += 1;
        }
        if (cond) sado.ComboSetting(i);
    }
}
function Extip_UnitGroup(cp, minion_order) {
    foreach (unit : Extip_SkillGroup.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        if (type == 1) 
        {
            //E 공격용 배슬
            if (timer == 0)
            {
                if (sy.GetExtraDb(cunit, 1) > 0)
                {
                    cunit.unknown0x8C = 12;
                    sy.ExtraSubDb(cunit, 1, 1);
                    const x, y = cunit.posX, cunit.posY;
                    const angle = (sy.GetExtraDb(cunit, 2)+rand()%180)%360;
                    const dx, dy = lengthdir(128, angle);
                    sy.SetExtraDb(cunit, 2, angle);
                    //좌표이동
                    setloc(targetLoc_S, x, y);
                    setloc(minionLoc, x + dx, y + dy);
                    Order(skill_Unit_1, cp, targetLoc_S, Move, minionLoc);
                    //유닛공격
                    sy.Unit_Create_Sudden(cp, skill_Unit_2, bufferLoc, targetLoc_S, 4);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    KillUnit(effect_Unit, cp);
                } else {
                    cunit.unknown0x86 = 2;
                    cunit.unknown0x8C = 0;
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 2)
        {
            //E 끝나면 멈춤
            if (timer == 0)
            {
                cunit.unknown0x8C = 3;
                cunit.groundWeaponCooldown = 20;
                cunit.orderID = 107;
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (Extip_SkillControl & 1)
            {
                //골리앗 공격!
                cunit.setloc(targetLoc_S);
                sy.Unit_Create_Sudden(cp, skill_Unit_2, bufferLoc, targetLoc_S, 4);
                sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                KillUnit(effect_Unit, cp);
            }
            if (Extip_SkillControl & 2)
            {
                //영웅에게 뭉치기!
                cunit.setloc(targetLoc_S);
                Order(skill_Unit_1, cp, targetLoc_S, Move, heroLoc);
                cunit.unknown0x86 = 3;
                cunit.unknown0x8C = 0;
                sy.SetExtraDb(cunit, 1, 3);
            }
        }
        else if (type == 3)
        {
            //영웅에게 뭉치기!
            cunit.setloc(targetLoc_S);
            Order(skill_Unit_1, cp, targetLoc_S, Move, heroLoc);
            if (timer == 0)
            {
                if (sy.GetExtraDb(cunit, 1) > 0)
                {
                    sy.ExtraSubDb(cunit, 1, 1);
                    cunit.unknown0x8C = 24;
                    sy.Unit_Create(cp, skill_Unit_2, bufferLoc, targetLoc_S);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    KillUnit(effect_Unit, cp);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (Extip_SkillControl & 4)
            {
                //무작위 방향으로 사출
                cunit.unknown0x86 = 4;
                cunit.unknown0x8C = 0;
                cunit.orderID = 187;
                cunit.orderState = 0;
            }
        }
        else if (type == 4)
        {
            //무작위 방향으로 사출
            if (timer == 0)
            {
                if (sy.GetExtraDb(cunit, 1) > 0)
                {
                    sy.ExtraSubDb(cunit, 1, 1);
                    cunit.unknown0x8C = 24;
                    cunit.setloc(targetLoc_S);
                    sy.Unit_Create(cp, skill_Unit_2, bufferLoc, targetLoc_S);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    KillUnit(effect_Unit, cp);
                    //유닛이동
                    cunit.orderID = 187;
                } else {
                    cunit.orderID = 0;
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
    }
    //minion_order : 1: 집결, 2: 거점, 4: 생성(800min)
    if (minion_order & 4)
    {
        if (minion_Cur >= minion_Limit)
        {
            printAllAt(6, "\x04하수인 소환 실패 \x02(\x04최대치 제한!\x02)");
            return;
        }
        if (Accumulate(cp, AtLeast, minion_Cost, Ore)) //미네랄확인
        {
            //텍스트 출력
            const x, y = getlocTL(heroLoc);
            effect_Unit_Sprite.image = sc.image_Queen;
            //하수인 생성
            const epd = sy.Unit_Create(cp, Extip_Minion_Unit, bufferLoc, heroLoc);
            //이펙트 유닛 생성
            sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
            KillUnit(effect_Unit, cp);
            sc.Reset_Change(effect_Unit_Sprite);
            if (epd > 0)
            {
                //자원 감소
                SetResources(cp, Subtract, minion_Cost, Ore);
                printAllAt(6, "\x04하수인 소환 성공 \x02(\x08-\x07{}\x03Gold\x02)", minion_Cost);
                Extip_MinionGroup_Main.add(epd);
                sy.SetExtraDb(epd, 0, 5);
                minion_Cur += 1;
            } else {
                //유닛제한으로 생성 실패
                printAllAt(6, "\x04하수인 소환 실패 \x02(\x04유닛 제한 오류!\x02)");
            }
        } else {
            //자원부족으로 하수인 생성 실패
            printAllAt(6, "\x04하수인 소환 실패 \x02(\x04자원 부족!\x02)");
        }
    }
    //거점 생성
    if (minion_order & 2)
    {
        for (var i = 0; i < 3; i++) {
            if (FOB_Exist[i] == false)
            {
                //최초 생성
                const epd = sy.Unit_Create(cp, FOB_Unit, bufferLoc, heroLoc);
                wwrite_epd(epd + 0x8C/4, 0, i);
                FOB_Epd[i] = epd;
                FOB_Exist[i] = true;
                break;
            }
        }
    }
    foreach (unit : Extip_MinionGroup_Main.cploop) {
        foreach (dead : unit.dying) {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        if (minion_order & 1)
        {
            //집결 명령
            cunit.unknown0x86 = 1;
            cunit.unknown0x8C = 0;
            const x, y = getlocTL(mouseLoc+cp);
            sy.SetExtraDb(cunit, 1, x);
            sy.SetExtraDb(cunit, 2, y);
            continue;
        }
        if (type == 0)
        {
            //휴식 상태
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                //거점 유닛 할당시키기
                for (var i = 0; i < 3; i++) {
                    if (FOB_Exist[i] == true && FOB_Count[i] < 6)
                    {
                        FOB_Count[i] += 1;
                        const epd = unit.epd;
                        if (i == 0) Extip_MinionGroup_FOB_1.add(epd);
                        else if (i == 1) Extip_MinionGroup_FOB_2.add(epd);
                        else if (i == 2) Extip_MinionGroup_FOB_3.add(epd);
                        unit.remove();
                    }
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1) 
        {
            //마우스 위치에 집결
            const tx = sy.GetExtraDb(cunit, 1);
            const ty = sy.GetExtraDb(cunit, 2);
            setloc(targetLoc_S, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(Extip_Minion_Unit, cp, minionLoc, Move, targetLoc_S);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, targetLoc_S) < 128)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 6;
                Order(Extip_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                cunit.set_collision();
            }
        }
        else if (type == 2)
        {
            //약간의 버퍼링
            if (timer == 0)
            {
                cunit.unknown0x86 = 0;
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 3)
        {
            //거점 할당 해제시 영웅에게 모이기
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                const tx, ty = getlocTL(heroLoc);
                cunit.setloc(minionLoc);
                Order(Extip_Minion_Unit, cp, minionLoc, Move, heroLoc);
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, heroLoc) < 128)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 6;
                Order(Extip_Minion_Unit, cp, minionLoc, Attack, heroLoc);
                cunit.set_collision();
            }
        }
    }
    foreach (unit : Extip_MinionGroup_FOB_1.cploop) {
        foreach (dead : unit.dying) {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[0] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Extip_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[0] + 0x28/4);
                setloc(targetLoc_S, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, targetLoc_S) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(Extip_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(Extip_Minion_Unit, cp, minionLoc, Patrol, targetLoc_S);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[0] + 0x28/4);
            setloc(targetLoc_S, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(Extip_Minion_Unit, cp, minionLoc, Move, targetLoc_S);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, targetLoc_S) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(Extip_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                cunit.set_collision();
            }
        }
    }
    foreach (unit : Extip_MinionGroup_FOB_2.cploop) {
        foreach (dead : unit.dying) {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[1] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Extip_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[1] + 0x28/4);
                setloc(targetLoc_S, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, targetLoc_S) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(Extip_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(Extip_Minion_Unit, cp, minionLoc, Patrol, targetLoc_S);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[1] + 0x28/4);
            setloc(targetLoc_S, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(Extip_Minion_Unit, cp, minionLoc, Move, targetLoc_S);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, targetLoc_S) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(Extip_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                cunit.set_collision();
            }
        }
    }
    foreach (unit : Extip_MinionGroup_FOB_3.cploop) {
        foreach (dead : unit.dying) {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[2] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Extip_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[2] + 0x28/4);
                setloc(targetLoc_S, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, targetLoc_S) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(Extip_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(Extip_Minion_Unit, cp, minionLoc, Patrol, targetLoc_S);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[2] + 0x28/4);
            setloc(targetLoc_S, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(Extip_Minion_Unit, cp, minionLoc, Move, targetLoc_S);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, targetLoc_S) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(Extip_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                cunit.set_collision();
            }
        }
    }
    Extip_SkillControl = 0;
    Extip_GroupControl = 0;
}

function Extip_FOB_Remove(cp, index) {
    //내부 값 초기화
    FOB_Count[index] = 0;
    FOB_Epd[index] = 0;
    FOB_Exist[index] = false;
}
function Extip_SkillRemove(cp, combo) {
    if (combo == 5)
    {
        //W
        KillUnit(skill_Unit_1, cp);
    }
    else if (combo == 7)
    {
        //W-W
        KillUnit(skill_Unit_1, cp);
    }
    else if (combo == 9)
    {
        //E
        KillUnit(skill_Unit_1, cp);
    }
}