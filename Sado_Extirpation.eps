function Extip_Skill(cp, epd, type, timer, max) {
    if (timer == 0) Extip_UnitSetting(cp, type, 0);
    const Ncp = cp + 8;
    switch (type) {
        case 1: //Q
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(targetLoc_F, x, y);
                sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, heroLoc, 5);
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                KillUnit(effect_Unit, cp);
            }
            if (timer == 3) {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Square_3[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 5);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    KillUnit(effect_Unit, cp);
                }
            }
            if (timer == 6)
            {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Square_5[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 5);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    KillUnit(effect_Unit, cp);
                }
            }
            break;
        case 2: //Q-Q
            if (timer%2 == 0 && timer < 15)
            {
                const x, y = getlocTL(heroLoc);
                for (var i = 0; i < 2; i++) {
                    const count = rand()%3;
                    var size = 0;
                    var dx, dy = 0, 0;
                    switch (count) {
                        case 0:
                            size = rand()%8;
                            dx, dy = dd.shape_Square_3[size];
                            break;
                        case 1:
                            size = rand()%16;
                            dx, dy = dd.shape_Square_5[size];
                            break;
                        case 2:
                            size = rand()%24;
                            dx, dy = dd.shape_Square_7[size];
                            break;
                    
                        default:
                            break;
                    }
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 5);
                    sy.Unit_Create_Sudden(cp, skill_Unit_2, bufferLoc, targetLoc_S, 5);
                }
            }
            break;
        case 3: //Q-Q-Q
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(targetLoc_F, x, y);
            }
            if (timer%4 == 0 && timer < 20)
            {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 5; i++) {
                    const index = (timer/3 + i)%5;
                    const dx, dy = dd.shape_Line_5[index];
                    setloc(targetLoc_S, x + dx, y + dy + (i-2)*48);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 4);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                }
                KillUnit(effect_Unit, cp);
            }
            break;
        case 4: //Q-E
            if (timer == 0)
            {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 32; i++) {
                    const dx, dy = dd.shape_Square_9[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 6);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                }
                KillUnit(effect_Unit, cp);
            }
            break;
        case 5: //W
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(targetLoc_F, x, y);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_192[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    sy.Unit_Create(cp, skill_Unit_1, bufferLoc, targetLoc_S);
                }
                KillUnit(effect_Unit, cp);
            }
            break;
        case 6: //W-Q
            if (timer%48 == 0 && timer < 15*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            if (timer%24 == 0 && timer > 15*24 && timer < 18*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            if (timer%8 == 0 && timer > 18*24 && timer < 20*24)
            {
                const image_OriginId = effect_Unit_Sprite.image;
                const drawing_OriginId = effect_Unit_Sprite.image.drawingFunction;
                effect_Unit_Sprite.image = sc.image_Over;
                effect_Unit_Sprite.image.drawingFunction = sc.drawing_Green;
                sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
                effect_Unit_Sprite.image = image_OriginId;
                effect_Unit_Sprite.image.drawingFunction = drawing_OriginId;
                KillUnit(effect_Unit, cp);
            }
            const amount = 50*256/24;
            sy.Unit_Healing_Count(CUnit(epd), cp, amount);
            break;
        case 7: //W-W
            if (timer == 0)
            {
                const x, y = getlocTL(targetLoc_F);
                TE.SetPColor(Ncp, color_White);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_160[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    sy.Unit_Create(cp, skill_Unit_1, bufferLoc, targetLoc_S);
                }
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_192[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                }
                KillUnit(effect_Unit, cp);
            }
            break;
        case 8: //W-W-W
            if (timer == 0)
            {
                const x, y = getlocTL(targetLoc_F);
                TE.SetPColor(Ncp, color_White);
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_128[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    sy.Unit_Create(cp, skill_Unit_1, bufferLoc, targetLoc_S);
                }
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_160[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                }
                for (var i = 0; i < 16; i++) {
                    const dx, dy = dd.shape_Circle_192[i];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                }
                KillUnit(effect_Unit, cp);
            }
            if (timer == max)
            {
                KillUnit(skill_Unit_1, cp);
            }
            break;
        case 9: //E
            if (timer == 0)
            {
                for (var i = 0; i < 4; i++) {
                    for (var j = 0; j < 5; j++) {
                        const x, y = getlocTL(heroLoc);
                        const dx, dy = dd.shape_Cross_dx[i], dd.shape_Cross_dy[i];
                        setloc(targetLoc_S, x + dx*j, y + dy*j);
                        const epd = sy.Unit_Create(cp, skill_Unit_1, bufferLoc, targetLoc_S);
                        Extip_SkillGroup.add(epd);
                        const cunit = CUnit(epd);
                        cunit.unknown0x86 = 1;
                        cunit.unknown0x8C = 0;
                        cunit.set_invincible();
                        sy.SetExtraDb(cunit, 0, 5);
                        sy.SetExtraDb(cunit, 1, 7);
                        sy.SetExtraDb(cunit, 2, rand()%360);
                    }
                }
            }
            break;
        case 10: //E-Q
            if (timer < 30) 
            {
                if (timer%3 == 0)
                {
                    Extip_SkillControl += 1;
                }
            }
            if (timer == max)
            {
                KillUnit(skill_Unit_1, cp);
                KillUnit(skill_Unit_2, cp);
            }
            break;
        case 11: //E-E
            if (timer == 0)
            {
                Extip_SkillControl += 2;
            }
            if (timer == 90)
            {
                Extip_SkillControl += 4;
            }
            if (timer == max)
            {
                KillUnit(skill_Unit_2, cp);
            }
            break;
        case 12: //R
            break;
    
        default:
            break;
    }
    if (timer == max) 
    {
        Extip_UnitSetting_Reset();
        return true;
    }
    return false;
}
function Extip_Skill_Enhance(cp, epd, type, timer, max) {
    if (timer == 0) Extip_UnitSetting(cp, type, 1);
    const Ncp = cp + 8;
    switch (type) {
        case 1: //Q
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                setloc(searchLoc, x, y);
                dilateloc(searchLoc, 196, 196);
                RemoveUnit(0, P12);
                MoveLocation(targetLoc_F, "Men", NonAlliedVictoryPlayers, searchLoc);
                TE.AttackGround(searchLoc, targetLoc_F, skill_Unit_2, dummyUnit, cp);
            }
            else if (timer == 4) {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(targetLoc_S, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    }
                }
            }
            else if (timer == 6)
            {
                RemoveUnit(effect_Unit, cp);
                const x, y = getlocTL(targetLoc_F);
                TE.SetPColor(Ncp, color_Black);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(targetLoc_S, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                        TE.SetUnitColorEPD(epd, Ncp);
                    }
                    setloc(targetLoc_S, x + dd.shape_Straight_dy[i], y + dd.shape_Straight_dy[i]);
                    const epd_2 = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                    TE.SetUnitColorEPD(epd_2, Ncp);
                }
            }
            break;
        case 2: //Q-Q
            if (timer == 0 || timer == 8)
            {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(targetLoc_S, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    }
                }
            }
            else if (timer == 2 || timer == 10)
            {
                RemoveUnit(effect_Unit, cp);
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(targetLoc_S, x + dd.shape_Cross_dx[i]*j, y + dd.shape_Cross_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                        Unit_Color_Change(cp, epd, color_ArmyD);
                    }
                }
            }
            else if (timer == 4)
            {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(targetLoc_S, x + dd.shape_Straight_dy[i]*j, y + dd.shape_Straight_dy[i]*j);
                        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    }
                }
            }
            else if (timer == 6)
            {
                RemoveUnit(effect_Unit, cp);
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 4; j++) {
                        setloc(targetLoc_S, x + dd.shape_Straight_dy[i]*j, y + dd.shape_Straight_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                        Unit_Color_Change(cp, epd, color_ArmyD);
                    }
                }
            }
            break;
        case 3: //Q-W
            if (timer == 2)
            {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_64[i*2];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                }
            }
            else if (timer == 4)
            {
                KillUnit(effect_Unit, cp);
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 3; j++) {
                        setloc(targetLoc_S, x + dd.shape_Straight_dy[i]*j, y + dd.shape_Straight_dy[i]*j);
                        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                        Unit_Color_Change(cp, epd, color_ArmyD);
                    }
                }
                for (var i = 0; i < 4; i++) {
                    for (var j = 1; j < 2; j++) {
                        setloc(targetLoc_S, x + dd.shape_Straight_dy[i]*j, y + dd.shape_Straight_dy[i]*j);
                        TE.AttackGround(targetLoc_S, targetLoc_S, skill_Unit_2, dummyUnit, cp);
                    }
                }
            }
            break;
        case 4: //Q-E
            if (timer == 0 || timer == 10 || timer == 20)
            {
                const x, y = getlocTL(targetLoc_F);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_32[i*2];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                }
            }
            if (timer == 2 || timer == 12 || timer == 22)
            {
                RemoveUnit(effect_Unit, cp);
            }
            if (timer == 3 || timer == 13 || timer == 23)
            {
                const x, y = getlocTL(targetLoc_F);
                const offset = (timer == 3 || timer == 23) ? 0 : 1;
                TE.SetPColor(Ncp, color_ArmyF);
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_32[i*2 + offset];
                    setloc(targetLoc_S, x + dx, y + dy);
                    const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 3);
                    TE.SetUnitColorEPD(epd, Ncp);
                }
                for (var i = 0; i < 8; i++) {
                    const dx, dy = dd.shape_Circle_64[i*2];
                    setloc(targetLoc_S, x + dx, y + dy);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                }
