function Plague_Skill(cp, epd, type, timer, max) {
    if (timer == 0) Plague_UnitSetting(cp, type, 0);
    const Ncp = cp + 8;
    switch (type) {
        case 1: //Q
            const x, y = getlocTL(heroLoc);
            setloc(searchLoc, x, y);
            dilateloc(searchLoc, 160, 160);
            MoveLocation(targetLoc_F, "Men", NonAlliedVictoryPlayers, searchLoc);
            Order(skill_Unit_1, cp, centerLoc, Move, targetLoc_F);
            if (timer == 0)
            {
                temp_Count = 0;
                Plague_SkillGroup.add(sy.Unit_Create(cp, skill_Unit_1, bufferLoc, heroLoc));
            }
            if (timer < 5*12)
            {
                if (timer%12 == 0)
                {
                    //럴커 생성
                    MoveLocation(targetLoc_S, skill_Unit_1, cp, centerLoc);
                    sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, targetLoc_S, 0, 1);
                    sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, targetLoc_S, 0, 1);
                    //이펙트 유닛
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    KillUnit(effect_Unit, cp);
                    temp_Count += 2;
                }
            }
            break;
        case 2: //Q-Q
            if (timer == 0)
            {
                Plague_SkillControl += 1;
            }
            break;
        case 3: //Q-Q-Q
            if (timer == 0)
            {
                KillUnit(skill_Unit_1, cp);
                var attempt = 0;
                while (temp_Count > 0) {
                    RemoveUnit(0, P12);
                    MoveLocation(targetLoc_S, skill_Unit_2, cp, centerLoc);
                    RemoveUnitAt(1, skill_Unit_2, targetLoc_S, cp);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 8);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 8);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    temp_Count -= 1;
                    attempt += 1;
                    if (attempt > 250) break;
                }
            }
            KillUnit(effect_Unit, cp);
            break;
        case 4: //Q-Q-W
            if (timer == 0)
            {
                Plague_SkillControl += 1;
            }
            if (timer == max)
            {
                KillUnit(skill_Unit_1, cp);
                KillUnit(skill_Unit_2, cp);
            }
            break;
        case 5: //W
            if (timer == 0)
            {
                Plague_GroupControl += 1; //추가 공격 생성
            }
            break;
        case 6: //W-Q
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                for (var i = 0; i < 2; i++) {
                    if (plague_Curruption_Count < 6)
                    {
                        setloc(targetLoc_S, x + dd.shape_Cross_dx[i*2], y + dd.shape_Cross_dy[i*2]);
                        const epd = sy.Unit_Create(cp, plague_Curruption, bufferLoc, targetLoc_S);
                        const tepd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 8);
                        if (epd && tepd)
                        {
                            //둘다 문제 없이 생성될 때에만 그룹에 넣기
                            const cunit = CUnit.cast(epd);
                            const tcunit = CUnit.cast(tepd);
                            tcunit.orderTarget = cunit;
                            tcunit.order = 10;
                            cunit.unknown0x86 = 2;
                            cunit.unknown0x8C = 0;
                            Plague_SkillGroup.add(epd);
                            plague_Curruption_Count += 1;
                        } else {
                            if (epd) bwrite_epd(epd + 0x4C/4, 1, 0);
                        }
                    }
                }
            }
            if (timer == max)
            {
                SetInvincibility(Enable, plague_Curruption, cp, centerLoc);
            }
            break;
        case 7: //W-Q-Q
            if (timer == 0)
            {
                Plague_GroupControl += 2; //이레딧 공격 설정
            }
            break;
        case 8: //W-Q-W
            if (timer == 0)
            {
                Plague_SkillControl += 4;
            }
            if (timer == max)
            {
                KillUnit(skill_Unit_1, cp);
                KillUnit(skill_Unit_2, cp);
            }
            break;
        case 9: //E
            if (timer == 0)
            {
                Plague_GroupControl += 16; //하수인 분열!
            }
            break;
        case 10: //E-Q
            if (timer == 0)
            {
                Plague_GroupControl += 4; //하수인 공&이속 업 시작
                plague_Minion_Unit_Weapon.cooldown = 9;
                toogle_Minion_Upgrade = true;
            }
            if (timer == max)
            {
                Plague_GroupControl += 8; //하수인 공&이속 업 끝
                plague_Minion_Unit_Weapon.cooldown = 14;
                toogle_Minion_Upgrade = false;
            }
            break;
        case 11: //R
            Plague_GroupControl += 64;
            if (timer%24 == 0)
            {
                Plague_GroupControl += 1;
            }
            break;
    
        default:
            break;
    }
    if (timer == max) 
    {
        Plague_UnitSetting_Reset();
        return true;
    }
    return false;
}
function Plague_Skill_Enhance(cp, epd, type, timer, max) {
    if (timer == 0) Plague_UnitSetting(cp, type, 0);
    const Ncp = cp + 8;
    switch (type) {
        case 1: //Q
            const x, y = getlocTL(heroLoc);
            setloc(searchLoc, x, y);
            dilateloc(searchLoc, 160, 160);
            MoveLocation(targetLoc_F, "Men", NonAlliedVictoryPlayers, searchLoc);
            Order(skill_Unit_1, cp, centerLoc, Move, targetLoc_F);
            if (timer == 0)
            {
                temp_Count = 0;
                Plague_SkillGroup.add(sy.Unit_Create(cp, skill_Unit_1, bufferLoc, heroLoc));
            }
            if (timer < 6*12)
            {
                if (timer%12 == 0)
                {
                    //럴커 생성
                    MoveLocation(targetLoc_S, skill_Unit_1, cp, centerLoc);
                    sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, targetLoc_S, 0, 1);
                    sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, targetLoc_S, 0, 1);
                    //이펙트 유닛
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    KillUnit(effect_Unit, cp);
                    temp_Count += 2;
                }
            }
            break;
        case 2: //Q-Q
            if (timer == 0)
            {
                Plague_SkillControl += 2;
            }
            break;
        case 3: //Q-Q-Q
            if (timer == 0)
            {
                KillUnit(skill_Unit_1, cp);
                var attempt = 0;
                while (temp_Count > 0) {
                    RemoveUnit(0, P12);
                    MoveLocation(targetLoc_S, skill_Unit_2, cp, centerLoc);
                    RemoveUnitAt(1, skill_Unit_2, targetLoc_S, cp);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 8);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 8);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 8);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    temp_Count -= 1;
                    attempt += 1;
                    if (attempt > 300) {
                        temp_Count = 0;
                        break;
                    }
                }
            }
            KillUnit(effect_Unit, cp);
            break;
        case 4: //Q-Q-W
            if (timer == 0)
            {
                Plague_SkillControl += 2;
            }
            if (timer == max)
            {
                KillUnit(skill_Unit_1, cp);
                KillUnit(skill_Unit_2, cp);
            }
            break;
        case 5: //W
            if (timer == 0)
            {
                Plague_GroupControl += 128; //추가 공격 생성
            }
            break;
        case 6: //W-Q
            if (timer == 0)
            {
                const x, y = getlocTL(heroLoc);
                for (var i = 0; i < 4; i++) {
                    if (plague_Curruption_Count < 9)
                    {
                        setloc(targetLoc_S, x + dd.shape_Cross_dx[i], y + dd.shape_Cross_dy[i]);
                        const epd = sy.Unit_Create(cp, plague_Curruption, bufferLoc, targetLoc_S);
                        const tepd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 8);
                        if (epd && tepd)
                        {
                            //둘다 문제 없이 생성될 때에만 그룹에 넣기
                            const cunit = CUnit.cast(epd);
                            const tcunit = CUnit.cast(tepd);
                            tcunit.orderTarget = cunit;
                            tcunit.order = 10;
                            cunit.unknown0x86 = 2;
                            cunit.unknown0x8C = 0;
                            Plague_SkillGroup.add(epd);
                            plague_Curruption_Count += 1;
                        } else {
                            if (epd) bwrite_epd(epd + 0x4C/4, 1, 0);
                        }
                    }
                }
            }
            if (timer == max)
            {
                SetInvincibility(Enable, plague_Curruption, cp, centerLoc);
            }
            break;
        case 7: //W-Q-Q
            if (timer == 0)
            {
                Plague_GroupControl += 2; //이레딧 공격 설정
                Plague_tempHeal = 1;
            }
            break;
        case 8: //W-Q-W
            if (timer == 0)
            {
                Plague_SkillControl += 8;
            }
            if (timer == max)
            {
                KillUnit(skill_Unit_1, cp);
                KillUnit(skill_Unit_2, cp);
            }
            break;
        case 9: //E
            if (timer == 0)
            {
                Plague_GroupControl += 512; //하수인 분열!
            }
            break;
        case 10: //E-Q
            if (timer == 0)
            {
                Plague_GroupControl += 4; //하수인 공&이속 업 시작
                plague_Minion_Unit_Weapon.cooldown = 6;
                toogle_Minion_Upgrade = true;
            }
            if (timer == max)
            {
                Plague_GroupControl += 8; //하수인 공&이속 업 끝
                plague_Minion_Unit_Weapon.cooldown = 14;
                toogle_Minion_Upgrade = false;
            }
            break;
        case 11: //R
            Plague_GroupControl += 64;
            if (timer%24 == 0)
            {
                Plague_GroupControl += 128;
            }
            break;
    
        default:
            break;
    }
    if (timer == max) 
    {
        Plague_UnitSetting_Reset();
        return true;
    }
    return false;
}
function Plague_Skill_Main(cp, sado_Main: EUDArray) {
    const sado = sdo.Sado.cast(sado_Main[cp]);
    for (var i = 1; i < 30; i++) {
        const info = sdo.Skill_Info.cast(sado.info[i]);
        var cond = false;
        if (info.isActived)
        {
            if (info.isEnhance) cond = Plague_Skill_Enhance(cp, sado.epd, info.type, info.timer, info.maxtime);
            else cond = Plague_Skill(cp, sado.epd, info.type, info.timer, info.maxtime);
            info.timer += 1;
        }
        if (cond) sado.ComboSetting(i);
    }
}
function Plague_FOB_alloc(cunit: CUnit) {
    for (var i = 0; i < 3; i++) {
        if (FOB_Exist[i] == true && FOB_Count[i] < 6)
        {
            FOB_Count[i] += 1;
            if (i == 0) Plague_MinionGroup_FOB_1.add(cunit);
            else if (i == 1) Plague_MinionGroup_FOB_2.add(cunit);
            else if (i == 2) Plague_MinionGroup_FOB_3.add(cunit);
            cunit.unknown0x86 = 0;
            cunit.unknown0x8C = 0;
            return true;
        }
    }
    return false;
}
function Plague_FOB_alloc_ary(cunit: CUnit, type) {
    var cond = 0;
    if (FOB_Exist[type] == true && FOB_Count[type] < 6)
    {
        FOB_Count[type] += 1;
        if (type == 0) {
            Plague_MinionGroup_FOB_1.add(cunit);
            cond = 1;
        }
        if (type == 1) {
            Plague_MinionGroup_FOB_2.add(cunit);
            cond = 1;
        }
        if (type == 2) {
            Plague_MinionGroup_FOB_3.add(cunit);
            cond = 1;
        }
        if (cond) {
            cunit.unknown0x86 = 0;
            cunit.unknown0x8C = 0;
            return true;
        }
    }
    return false;
}
function Plague_MinionSkill(cp, cunit: CUnit, type) {
    if (Plague_GroupControl & 1)
    {
        //W스킬 소환
        cunit.setloc(targetLoc_S);
        skill_Unit_3_Weapon.damage = 22;
        skill_Unit_3_Weapon.damageBonus = 6;
        const image_OriginId = effect_Unit_Sprite.image;
        effect_Unit_Sprite.image = sc.image_Scourge;
        sy.Unit_Create_Sudden(cp, skill_Unit_3, bufferLoc, targetLoc_S, 8);
        sy.Unit_Create_Sudden(cp, skill_Unit_3, bufferLoc, targetLoc_S, 8);
        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
        effect_Unit_Sprite.image = image_OriginId;
        KillUnit(effect_Unit, cp);
    }
    if (Plague_GroupControl & 128)
    {
        //W스킬 소환
        cunit.setloc(targetLoc_S);
        skill_Unit_3_Weapon.damage = 22;
        skill_Unit_3_Weapon.damageBonus = 6;
        const image_OriginId = effect_Unit_Sprite.image;
        effect_Unit_Sprite.image = sc.image_Scourge;
        sy.Unit_Create_Sudden(cp, skill_Unit_3, bufferLoc, targetLoc_S, 8);
        sy.Unit_Create_Sudden(cp, skill_Unit_3, bufferLoc, targetLoc_S, 8);
        sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, targetLoc_S, 18, 1);
        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
        effect_Unit_Sprite.image = image_OriginId;
        KillUnit(effect_Unit, cp);
    }
    if (Plague_GroupControl & 2)
    {
        //W-Q-Q이레딧
        cunit.setloc(targetLoc_S);
        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, targetLoc_S, 12);
        const tcunit = CUnit(epd);
        tcunit.orderTarget = cunit;
        tcunit.orderID = 10;
    }
    if (Plague_GroupControl & 4)
    {
        //하수인 공&이속 업
        cunit.set_speed_upgrade();
    }
    if (Plague_GroupControl & 8)
    {
        //하수인 공&이속 업 끝
        cunit.clear_speed_upgrade();
    }
    if (Plague_GroupControl & 16)
    {
        //하수인 분열!
        if (minion_Cur < minion_Limit)
        {
            cunit.setloc(targetLoc_S);
            const curHp = cunit.hp;
            RemoveUnitAt(1, plague_Minion_Unit, targetLoc_S, cp);
            //거점 할당 삭제
            if (type < 4)
            {
                FOB_Count[type] -= 1;
            }
            for (var i = 0; i < 2; i++) {
                const epd = sy.Unit_Create(cp, plague_Minion_Unit, bufferLoc, targetLoc_S);
                const tcunit = CUnit(epd);
                tcunit.hp = curHp/2;
                tcunit.unknown0x86 = 4;
                tcunit.unknown0x8C = 0;
                if (!Plague_FOB_alloc_ary(tcunit, type)) {
                    Plague_MinionGroup_Main.add(tcunit);
                }
            }
            //이펙트
            sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
            KillUnit(effect_Unit, cp);
            minion_Cur += 2;
            return true;
        }
    }
    if (Plague_GroupControl & 512)
    {
        //하수인 3배 분열!
        if (minion_Cur < minion_Limit-1)
        {
            cunit.setloc(targetLoc_S);
            const curHp = cunit.hp;
            RemoveUnitAt(1, plague_Minion_Unit, targetLoc_S, cp);
            //거점 할당 삭제
            if (type < 4)
            {
                FOB_Count[type] -= 1;
            }
            for (var i = 0; i < 3; i++) {
                const epd = sy.Unit_Create(cp, plague_Minion_Unit, bufferLoc, targetLoc_S);
                const tcunit = CUnit(epd);
                tcunit.hp = curHp/3;
                tcunit.unknown0x86 = 4;
                tcunit.unknown0x8C = 0;
                if (!Plague_FOB_alloc_ary(tcunit, type)) {
                    Plague_MinionGroup_Main.add(tcunit);
                }
            }
            //이펙트
            sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
            KillUnit(effect_Unit, cp);
            minion_Cur += 3;
            return true;
        }
    }
    if (Plague_GroupControl & 32)
    {
        //하수인 회복
        cunit.setloc(targetLoc_S);
        const image_OriginId = effect_Unit_Sprite.image;
        effect_Unit_Sprite.image = sc.image_Bengal;
        sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
        KillUnit(effect_Unit, cp);
        sy.Unit_Healing_Percent(cunit, cp, 100);
    }
    if (Plague_GroupControl & 64)
    {
        //하수인 회복
        sy.Unit_Healing_Percent(cunit, cp, 100);
    }
    if (cunit.irradiateTimer > 0 && Plague_tempHeal)
    {
        const timer = sy.GetExtraDb(cunit, 3);
        if (timer == 0)
        {
            sy.Unit_Healing_Percent(cunit, cp, 4);
            sy.SetExtraDb(cunit, 3, 24);
        } else {
            sy.ExtraSubDb(cunit, 3, 1);
        }
    }
    return false;
}
function Plague_UnitGroup(cp, minion_order) {
    foreach (unit : Plague_SkillGroup.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        if (type == 1) 
        {
            //계속 날라가기 + 럴커생성
            if (timer == 0)
            {
                //스킬 유닛 생성
                if (sy.GetExtraDb(cunit, 2) > 0)
                {
                    cunit.unknown0x8C = 12;
                    const angle = sy.GetExtraDb(cunit, 1);
                    const dx, dy = lengthdir(120, angle);
                    const x, y = cunit.posX, cunit.posY;
                    setloc(targetLoc_S, x, y);
                    setloc(minionLoc, x + dx, y + dy);
                    Order(skill_Unit_1, cp, targetLoc_S, Move, minionLoc);
                    //따로
                    sy.ExtraSubDb(cunit, 2, 1);
                    sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, targetLoc_S, 0, 1);
                    //이펙트 유닛
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, targetLoc_S);
                    KillUnit(effect_Unit, cp);
                    temp_Count += 1;
                } else {
                    cunit.setloc(targetLoc_S);
                    Order(skill_Unit_1, cp, targetLoc_S, Move, targetLoc_S);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
            sy.ExtraSubDb(cunit, 1, 2);
        }
        else if (type == 2)
        {
            //이레딧 시간 끝나면 죽기
            if (cunit.irradiateTimer == 1) {
                cunit.orderID = 0;
                plague_Curruption_Count -= 1;
            }
        }
        if (cunit.unitID == skill_Unit_1)
        {
            if (Plague_SkillControl & 1)
            {
                //3개로 분열하기
                cunit.setloc(targetLoc_S);
                RemoveUnitAt(1, skill_Unit_1, targetLoc_S, cp);
                const angle = rand()%120;
                for (var j = 0; j < 3; j++) {
                    const epd = sy.Unit_Create(cp, skill_Unit_1, bufferLoc, targetLoc_S);
                    bwrite_epd(epd + 0x84/4, 2, 1);
                    wwrite_epd(epd + 0x8C/4, 0, 0);
                    sy.SetExtraDb(epd, 0, 5);
                    sy.SetExtraDb(epd, 1, angle + j*120); //이동 각도
                    sy.SetExtraDb(epd, 2, 4); //생성 최대치
                    Plague_SkillGroup.add(epd);
                }
            }
            if (Plague_SkillControl & 2)
            {
                //4개로 분열하기
                cunit.setloc(targetLoc_S);
                RemoveUnitAt(1, skill_Unit_1, targetLoc_S, cp);
                const angle = rand()%90;
                for (var j = 0; j < 4; j++) {
                    const epd = sy.Unit_Create(cp, skill_Unit_1, bufferLoc, targetLoc_S);
                    bwrite_epd(epd + 0x84/4, 2, 1);
                    wwrite_epd(epd + 0x8C/4, 0, 0);
                    sy.SetExtraDb(epd, 0, 5);
                    sy.SetExtraDb(epd, 1, angle + j*90); //이동 각도
                    sy.SetExtraDb(epd, 2, 4); //생성 최대치
                    Plague_SkillGroup.add(epd);
                }
            }
        }
        if (cunit.unitID == plague_Curruption)
        {
            if (Plague_SkillControl & 4)
            {
                //3개로 분열하기
                cunit.setloc(targetLoc_S);
                // RemoveUnitAt(1, plague_Curruption, targetLoc_S, cp);
                const angle = rand()%120;
                for (var j = 0; j < 3; j++) {
                    const epd = sy.Unit_Create(cp, skill_Unit_1, bufferLoc, targetLoc_S);
                    bwrite_epd(epd + 0x84/4, 2, 1);
                    wwrite_epd(epd + 0x8C/4, 0, 0);
                    sy.SetExtraDb(epd, 0, 5);
                    sy.SetExtraDb(epd, 1, angle + j*120); //이동 각도
                    sy.SetExtraDb(epd, 2, 5); //생성 최대치
                    Plague_SkillGroup.add(epd);
                }
            }
            if (Plague_SkillControl & 8)
            {
                //4개로 분열하기
                cunit.setloc(targetLoc_S);
                // RemoveUnitAt(1, plague_Curruption, targetLoc_S, cp);
                const angle = rand()%90;
                for (var j = 0; j < 4; j++) {
                    const epd = sy.Unit_Create(cp, skill_Unit_1, bufferLoc, targetLoc_S);
                    bwrite_epd(epd + 0x84/4, 2, 1);
                    wwrite_epd(epd + 0x8C/4, 0, 0);
                    sy.SetExtraDb(epd, 0, 5);
                    sy.SetExtraDb(epd, 1, angle + j*90); //이동 각도
                    sy.SetExtraDb(epd, 2, 5); //생성 최대치
                    Plague_SkillGroup.add(epd);
                }
            }
        }
    }
    //minion_order : 1: 집결, 2: 거점, 4: 생성(800min)
    if (minion_order & 4)
    {
        if (Command(cp, AtLeast, minion_Limit, plague_Minion_Unit))
        {
            printAllAt(6, "\x04하수인 소환 실패 \x02(\x04최대치 제한!\x02)");
            return;
        }
        if (Accumulate(cp, AtLeast, minion_Cost, Ore)) //미네랄확인
        {
            //텍스트 출력
            const x, y = getlocTL(heroLoc);
            var image_OriginId = effect_Unit_Sprite.image;
            effect_Unit_Sprite.image = sc.image_Queen;
            //하수인 생성
            const epd = sy.Unit_Create(cp, plague_Minion_Unit, bufferLoc, heroLoc);
            //이펙트 유닛 생성
            sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
            KillUnit(effect_Unit, cp);
            effect_Unit_Sprite.image = image_OriginId;
            if (epd > 0)
            {
                //자원 감소
                SetResources(cp, Subtract, minion_Cost, Ore);
                printAllAt(6, "\x04하수인 소환 성공 \x02(\x08-\x07{}\x03Gold\x02)", minion_Cost);
                Plague_MinionGroup_Main.add(epd);
                minion_Cur += 1;
                if (toogle_Minion_Upgrade)
                {
                    SetMemoryXEPD(epd + 0xDC/4, SetTo, 0x10000000, 0x10000000);
                }
            } else {
                //유닛제한으로 생성 실패
                printAllAt(6, "\x04하수인 소환 실패 \x02(\x04유닛 제한 오류!\x02)");
            }
        } else {
            //자원부족으로 하수인 생성 실패
            printAllAt(6, "\x04하수인 소환 실패 \x02(\x04자원 부족!\x02)");
        }
    }//거점 생성
    if (minion_order & 2)
    {
        for (var i = 0; i < 3; i++) {
            if (FOB_Exist[i] == false)
            {
                //최초 생성
                const epd = sy.Unit_Create(cp, FOB_Unit, bufferLoc, heroLoc);
                wwrite_epd(epd + 0x8C/4, 0, i);
                FOB_Epd[i] = epd;
                FOB_Exist[i] = true;
                break;
            }
        }
    }
    foreach (unit : Plague_MinionGroup_Main.cploop) {
        foreach (dead : unit.dying) {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        if (minion_order & 1)
        {
            //집결 명령
            cunit.unknown0x86 = 1;
            cunit.unknown0x8C = 0;
            const x, y = getlocTL(mouseLoc+cp);
            sy.SetExtraDb(cunit, 1, x);
            sy.SetExtraDb(cunit, 2, y);
            continue;
        }
        if (type == 0)
        {
            //휴식 상태
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                //거점 유닛 할당시키기
                for (var i = 0; i < 3; i++) {
                    if (FOB_Exist[i] == true && FOB_Count[i] < 6)
                    {
                        FOB_Count[i] += 1;
                        const epd = unit.epd;
                        if (i == 0) Plague_MinionGroup_FOB_1.add(epd);
                        else if (i == 1) Plague_MinionGroup_FOB_2.add(epd);
                        else if (i == 2) Plague_MinionGroup_FOB_3.add(epd);
                        unit.remove();
                    }
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1) 
        {
            //마우스 위치에 집결
            const tx = sy.GetExtraDb(cunit, 1);
            const ty = sy.GetExtraDb(cunit, 2);
            setloc(targetLoc_S, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Move, targetLoc_S);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, targetLoc_S) < 128)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 6;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                cunit.set_collision();
            }
        }
        else if (type == 2)
        {
            //약간의 버퍼링
            if (timer == 0)
            {
                cunit.unknown0x86 = 0;
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 3)
        {
            //거점 할당 해제시 영웅에게 모이기
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                const tx, ty = getlocTL(heroLoc);
                cunit.setloc(minionLoc);
                Order(plague_Minion_Unit, cp, minionLoc, Move, heroLoc);
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, heroLoc) < 128)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 6;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, heroLoc);
                cunit.set_collision();
            }
        }
        else if (type == 4)
        {
            //분열 후 거점에 들어갈지 영웅에 모일지 계산
            //거점 유닛 할당시키기
            if (Plague_FOB_alloc(cunit)) unit.remove();
            //할당 안된 유닛은 영웅으로 모이기
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
        }
        if (Plague_MinionSkill(cp, cunit, 4))
        {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(cunit);
            unit.remove();
        }
    }
    foreach (unit : Plague_MinionGroup_FOB_1.cploop) {
        foreach (dead : unit.dying) {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[0] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Plague_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[0] + 0x28/4);
                setloc(targetLoc_S, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, targetLoc_S) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Patrol, targetLoc_S);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[0] + 0x28/4);
            setloc(targetLoc_S, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Move, targetLoc_S);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, targetLoc_S) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                cunit.set_collision();
            }
        }
        if (Plague_MinionSkill(cp, cunit, 0))
        {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(cunit);
            unit.remove();
        }
    }
    foreach (unit : Plague_MinionGroup_FOB_2.cploop) {
        foreach (dead : unit.dying) {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[1] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Plague_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[1] + 0x28/4);
                setloc(targetLoc_S, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, targetLoc_S) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Patrol, targetLoc_S);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[1] + 0x28/4);
            setloc(targetLoc_S, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Move, targetLoc_S);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, targetLoc_S) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                cunit.set_collision();
            }
        }
        if (Plague_MinionSkill(cp, cunit, 1))
        {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(cunit);
            unit.remove();
        }
    }
    foreach (unit : Plague_MinionGroup_FOB_3.cploop) {
        foreach (dead : unit.dying) {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[2] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Plague_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[2] + 0x28/4);
                setloc(targetLoc_S, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, targetLoc_S) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Patrol, targetLoc_S);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[2] + 0x28/4);
            setloc(targetLoc_S, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Move, targetLoc_S);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, targetLoc_S) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, targetLoc_S);
                cunit.set_collision();
            }
        }
        if (Plague_MinionSkill(cp, cunit, 2))
        {
            minion_Cur -= 1;
            sy.ExtraDb_Reset(cunit);
            unit.remove();
        }
    }
    Plague_GroupControl = 0;
    Plague_SkillControl = 0;
}

function Plague_FOB_Remove(cp, index) {
    //내부 값 초기화
    FOB_Count[index] = 0;
    FOB_Epd[index] = 0;
    FOB_Exist[index] = false;
}
function Plague_SkillRemove(cp, combo) {
    if (combo == 1)
    {
        //Q
        KillUnit(skill_Unit_1, cp);
        KillUnit(skill_Unit_2, cp);
    }
    else if (combo == 2)
    {
        //Q-Q
        KillUnit(skill_Unit_1, cp);
        KillUnit(skill_Unit_2, cp);
    }
}