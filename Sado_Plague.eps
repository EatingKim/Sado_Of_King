function Plague_Skill(cp, epd, type, timer, max) {
    if (timer == 0) Plague_UnitSetting(cp, type, 0);
    const Ncp = cp + 8;
    switch (type) {
        case 1: //Q
            const x, y = getlocTL(heroLoc);
            setloc(searchLoc, x, y);
            dilateloc(searchLoc, 160, 160);
            MoveLocation(targetLoc, "Men", NonAlliedVictoryPlayers, searchLoc);
            Order(skill_Unit_1, cp, centerLoc, Move, targetLoc);
            if (timer == 0)
            {
                temp_Count = 0;
                sy.Unit_Create(cp, skill_Unit_1, bufferLoc, heroLoc);
            }
            if (timer < 5*12)
            {
                if (timer%12 == 0)
                {
                    //럴커 생성
                    MoveLocation(tempLoc, skill_Unit_1, cp, centerLoc);
                    sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, tempLoc, 0, 1);
                    sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, tempLoc, 0, 1);
                    //이펙트 유닛
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    KillUnit(effect_Unit, cp);
                    temp_Count += 2;
                }
            }
            break;
        case 2: //Q-Q
            if (timer == 0)
            {
                MoveLocation(tempLoc, skill_Unit_1, cp, centerLoc);
                const x, y = getlocTL(tempLoc);
                KillUnitAt(1, skill_Unit_1, tempLoc, cp);
                const angle = rand()%120;
                for (var i = 0; i < 3; i++) {
                    const epd = sy.Unit_Create(cp, skill_Unit_1, bufferLoc, tempLoc);
                    bwrite_epd(epd + 0x84/4, 2, 1);
                    wwrite_epd(epd + 0x8C/4, 0, 0);
                    sy.SetExtraDb(epd, 0, 5);
                    sy.SetExtraDb(epd, 1, angle + i*120); //이동 각도
                    sy.SetExtraDb(epd, 2, 3); //생성 최대치
                    Plague_SkillGroup.add(epd);
                }
            }
            break;
        case 3: //Q-Q-Q
            if (timer == 0)
            {
                KillUnit(skill_Unit_1, cp);
                var attempt = 0;
                while (temp_Count > 0) {
                    RemoveUnit(0, P12);
                    MoveLocation(tempLoc, skill_Unit_2, cp, centerLoc);
                    RemoveUnitAt(1, skill_Unit_2, tempLoc, cp);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 8);
                    sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 8);
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    temp_Count -= 1;
                    attempt += 1;
                    if (attempt > 250) break;
                }
            }
            KillUnit(effect_Unit, cp);
            break;
        case 4: //Q-Q-W
            if (timer == 0)
            {
                for (var i = 0; i < 3; i++) {
                    MoveLocation(tempLoc, skill_Unit_1, cp, centerLoc);
                    const x, y = getlocTL(tempLoc);
                    RemoveUnitAt(1, skill_Unit_1, tempLoc, cp);
                    const angle = rand()%120;
                    for (var j = 0; j < 3; j++) {
                        const epd = sy.Unit_Create(P8, skill_Unit_1, bufferLoc, tempLoc);
                        bwrite_epd(epd + 0x84/4, 2, 1);
                        wwrite_epd(epd + 0x8C/4, 0, 0);
                        sy.SetExtraDb(epd, 0, 5);
                        sy.SetExtraDb(epd, 1, angle + j*120); //이동 각도
                        sy.SetExtraDb(epd, 2, 4); //생성 최대치
                        Plague_SkillGroup.add(epd);
                    }
                }
                GiveUnits(All, skill_Unit_1, P8, centerLoc, cp);
            }
            if (timer == max)
            {
                KillUnit(skill_Unit_1, cp);
                KillUnit(skill_Unit_2, cp);
            }
            break;
        case 5: //W
            if (timer == 0)
            {
                Plague_GroupControl += 1; //추가 공격 생성
            }
            break;
        case 6: //W-Q
            if (timer == 0)
            {
                for (var i = 0; i < 4; i++) {
                    const epd = sy.Unit_Create(cp, plague_Curruption, bufferLoc, heroLoc);
                    const tepd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, heroLoc, 8);
                    const cunit = CUnit.cast(epd);
                    const tcunit = CUnit.cast(tepd);
                    tcunit.orderTarget = cunit;
                    tcunit.order = 10;
                    sy.SetExtraDb(cunit, 0, 5);
                    sy.SetExtraDb(cunit, 1, 25*24);
                    Plague_SkillGroup.add(epd);
                }
            }
            if (timer == 6)
            {
                SetInvincibility(Enable, plague_Curruption, cp, centerLoc);
            }
            break;
        case 7: //W-Q-Q
            if (timer == 0)
            {
                Plague_GroupControl += 2; //이레딧 공격 설정
            }
            break;
        case 8: //W-W
            break;
        case 9: //E
            break;
        case 10: //E-Q
            break;
        case 11: //R
            break;
    
        default:
            break;
    }
    if (timer == max) 
    {
        Plague_UnitSetting_Reset();
        return true;
    }
    return false;
}
function Plague_Skill_Enhance(cp, epd, type, timer, max) {
    return false;
}
function Plague_Skill_Main(cp, sado_Main: EUDArray) {
    const sado = sdo.Sado.cast(sado_Main[cp]);
    for (var i = 1; i < 30; i++) {
        const info = sdo.Skill_Info.cast(sado.info[i]);
        var cond = 0;
        if (info.isActived)
        {
            if (info.isEnhance) cond = Plague_Skill_Enhance(cp, sado.epd, info.type, info.timer, info.maxtime);
            else cond = Plague_Skill(cp, sado.epd, info.type, info.timer, info.maxtime);
            info.timer += 1;
        }
        if (cond) sado.ComboSetting(i);
    }
}
function Plague_SkillControl(cp, cunit: CUnit) {
    if (Plague_GroupControl & 1)
    {
        cunit.setloc(tempLoc);
        sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 8);
        sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 8);
        sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
        KillUnit(effect_Unit, cp);
    }
    if (Plague_GroupControl & 2)
    {
        cunit.setloc(tempLoc);
        const epd = sy.Unit_Create_Sudden(cp, skill_Unit_1, bufferLoc, tempLoc, 12);
        const tcunit = CUnit(epd);
        tcunit.orderTarget = cunit;
        tcunit.orderID = 10;
    }
}

function Plague_UnitGroup(cp, minion_order) {
    foreach (unit : Plague_SkillGroup.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        if (type == 1) 
        {
            //계속 날라가기 + 럴커생성
            if (timer == 0)
            {
                cunit.unknown0x8C = 12;
                const angle = sy.GetExtraDb(cunit, 1);
                const dx, dy = lengthdir(120, angle);
                const x, y = cunit.posX, cunit.posY;
                setloc(tempLoc, x, y);
                setloc(minionLoc, x + dx, y + dy);
                Order(skill_Unit_1, cp, tempLoc, Move, minionLoc);
                //스킬 유닛 생성
                if (sy.GetExtraDb(cunit, 2) > 0)
                {
                    sy.ExtraSubDb(cunit, 2, 1);
                    sy.Unit_Create_Special(cp, skill_Unit_2, bufferLoc, tempLoc, 0, 1);
                    //이펙트 유닛
                    sy.Unit_Create(cp, effect_Unit, bufferLoc, tempLoc);
                    KillUnit(effect_Unit, cp);
                    temp_Count += 1;
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }

        const Rtimer = sy.GetExtraDb(cunit, 1);
        if (Rtimer == 0)
        {
            cunit.orderID = 0;
        } else {
            sy.ExtraSubDb(cunit, 1, 1);
        }
    }
    //minion_order : 1: 집결, 2: 거점, 4: 생성(800min)
    if (minion_order & 4)
    {
        if (Accumulate(cp, AtLeast, minion_Cost, Ore)) //미네랄확인
        {
            //텍스트 출력
            const x, y = getlocTL(heroLoc);
            effect_Unit_Sprite.image = sc.image_Queen;
            //하수인 생성
            const epd = sy.Unit_Create(cp, plague_Minion_Unit, bufferLoc, heroLoc);
            //이펙트 유닛 생성
            sy.Unit_Create(cp, effect_Unit, bufferLoc, heroLoc);
            KillUnit(effect_Unit, cp);
            sc.Reset_Change(effect_Unit_Sprite);
            if (epd > 0)
            {
                //자원 감소
                SetResources(cp, Subtract, minion_Cost, Ore);
                printAllAt(6, "\x04하수인 소환 성공 \x02(\x08-\x07{}\x03Gold\x02)", minion_Cost);
                Plague_MinionGroup_Main.add(epd);
            } else {
                //유닛제한으로 생성 실패
                printAllAt(6, "\x04하수인 소환 실패 \x02(\x04유닛 제한 오류!\x02)");
            }
        } else {
            //자원부족으로 하수인 생성 실패
            printAllAt(6, "\x04하수인 소환 실패 \x02(\x04자원 부족!\x02)");
        }
    }//거점 생성
    if (minion_order & 2)
    {
        for (var i = 0; i < 3; i++) {
            if (FOB_Exist[i] == false)
            {
                //최초 생성
                const epd = sy.Unit_Create(cp, FOB_Unit, bufferLoc, heroLoc);
                wwrite_epd(epd + 0x8C/4, 0, i);
                FOB_Epd[i] = epd;
                FOB_Exist[i] = true;
                break;
            }
        }
    }
    foreach (unit : Plague_MinionGroup_Main.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        if (minion_order & 1)
        {
            //집결 명령
            cunit.unknown0x86 = 1;
            cunit.unknown0x8C = 0;
            const x, y = getlocTL(mouseLoc+cp);
            sy.SetExtraDb(cunit, 1, x);
            sy.SetExtraDb(cunit, 2, y);
            continue;
        }
        if (type == 0)
        {
            //휴식 상태
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                //거점 유닛 할당시키기
                for (var i = 0; i < 3; i++) {
                    if (FOB_Exist[i] == true && FOB_Count[i] < 6)
                    {
                        FOB_Count[i] += 1;
                        const epd = unit.epd;
                        if (i == 0) Plague_MinionGroup_FOB_1.add(epd);
                        else if (i == 1) Plague_MinionGroup_FOB_2.add(epd);
                        else if (i == 2) Plague_MinionGroup_FOB_3.add(epd);
                        unit.remove();
                    }
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1) 
        {
            //마우스 위치에 집결
            const tx = sy.GetExtraDb(cunit, 1);
            const ty = sy.GetExtraDb(cunit, 2);
            setloc(tempLoc, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Move, tempLoc);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, tempLoc) < 128)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 6;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                cunit.set_collision();
            }
        }
        else if (type == 2)
        {
            //약간의 버퍼링
            if (timer == 0)
            {
                cunit.unknown0x86 = 0;
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 3)
        {
            //거점 할당 해제시 영웅에게 모이기
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                const tx, ty = getlocTL(heroLoc);
                cunit.setloc(minionLoc);
                Order(plague_Minion_Unit, cp, minionLoc, Move, heroLoc);
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, heroLoc) < 128)
            {
                cunit.unknown0x86 = 2;
                cunit.unknown0x8C = 6;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, heroLoc);
                cunit.set_collision();
            }
        }
        Plague_SkillControl(cp, cunit);
    }
    foreach (unit : Plague_MinionGroup_FOB_1.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[0] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Plague_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[0] + 0x28/4);
                setloc(tempLoc, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, tempLoc) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Patrol, tempLoc);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[0] + 0x28/4);
            setloc(tempLoc, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Move, tempLoc);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, tempLoc) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                cunit.set_collision();
            }
        }
    }
    foreach (unit : Plague_MinionGroup_FOB_2.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[1] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Plague_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[1] + 0x28/4);
                setloc(tempLoc, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, tempLoc) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Patrol, tempLoc);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[1] + 0x28/4);
            setloc(tempLoc, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Move, tempLoc);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, tempLoc) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                cunit.set_collision();
            }
        }
    }
    foreach (unit : Plague_MinionGroup_FOB_3.cploop) {
        foreach (dead : unit.dying) {
            sy.ExtraDb_Reset(dead.epd);
        }
        const cunit = CUnit(unit.epd);
        const type = cunit.unknown0x86;
        const timer = cunit.unknown0x8C;
        //그룹 할당 해제
        if (FOB_Epd[2] == 0)
        {
            cunit.unknown0x86 = 3;
            cunit.unknown0x8C = 0;
            cunit.remove_collision();
            Plague_MinionGroup_Main.add(unit.epd);
            unit.remove();
        }
        if (type == 0)
        {
            if (timer == 0)
            {
                //거점 위치랑 거리 비교
                const tx, ty = posread_epd(FOB_Epd[2] + 0x28/4);
                setloc(tempLoc, tx, ty);
                cunit.setloc(minionLoc);
                if (sy.LocationDistance(minionLoc, tempLoc) > 160)
                {
                    //거점에서 멀어지면 강제 이동
                    cunit.unknown0x86 = 1;
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                    cunit.set_collision();
                } else {
                    //거점 안이면 오더만 갱신
                    cunit.unknown0x8C = 24;
                    Order(plague_Minion_Unit, cp, minionLoc, Patrol, tempLoc);
                }
            } else {
                cunit.unknown0x8C -= 1;
            }
        }
        else if (type == 1)
        {
            //거점 위치랑 너무 멀어지면 강제 이동
            const tx, ty = posread_epd(FOB_Epd[2] + 0x28/4);
            setloc(tempLoc, tx, ty);
            cunit.setloc(minionLoc);
            //집결 명령 하달
            if (timer == 0)
            {
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Move, tempLoc);
                cunit.remove_collision();
            } else {
                cunit.unknown0x8C -= 1;
            }
            if (sy.LocationDistance(minionLoc, tempLoc) < 160)
            {
                cunit.unknown0x86 = 0;
                cunit.unknown0x8C = 24;
                Order(plague_Minion_Unit, cp, minionLoc, Attack, tempLoc);
                cunit.set_collision();
            }
        }
    }
    Plague_GroupControl = 0;
}

function Plague_FOB_Remove(cp, index) {
    //내부 값 초기화
    FOB_Count[index] = 0;
    FOB_Epd[index] = 0;
    FOB_Exist[index] = false;
}
function Plague_SkillRemove(cp, combo) {
    if (combo == 1)
    {
        //Q
        KillUnit(skill_Unit_1, cp);
        KillUnit(skill_Unit_2, cp);
    }
    else if (combo == 2)
    {
        //Q-Q
        KillUnit(skill_Unit_1, cp);
        KillUnit(skill_Unit_2, cp);
    }
}