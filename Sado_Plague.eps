function Unit_Color_Change(cp, epd, color) {
    const Ncp = cp+8;
    TE.SetUnitColorEPD(epd, Ncp);
    TE.SetPColor(Ncp, color);
}

function Plague_UnitSetting_Reset() {
    skill_Unit_1.airWeapon = 50;
    sc.Reset_Change(effect_Unit_Sprite);
    sc.Reset_Change(skill_Unit_1_Sprite);
    sc.Reset_Change(skill_Unit_1_Weapon_Sprite);
}

