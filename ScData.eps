function init() {
    for (var i = 0; i < 516; i++) {
        const sprite = Sprite(i);
        image_OriginId[i] = sprite.image;
    }
    for (var i = 0; i < 998; i++) {
        const image = Image(i);
        script_OriginId[i] = image.iscript;
        color_OriginId[i] = image.drawingFunction;
    }
}

function Reset_Change(sprite: Sprite) {
    const image = sprite.image;
    image.iscript = script_OriginId[image];
    image.drawingFunction = color_OriginId[image];
    sprite.image = image_OriginId[sprite];
}